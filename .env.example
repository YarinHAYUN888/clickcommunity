# Client (safe to expose in built SPA — protected by RLS). Never put service_role here.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_or_publishable_key
# Optional alias for the same anon/public key:
# VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Optional — documentation only for tooling / Dashboard links
# VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_REF

# -----------------------------------------------------------------------------
# OpenAI — סינון התאמת משתמש בהרשמה (src/lib/ai/analyzeUser.ts → runUserAnalysis).
# העתק את הקובץ הזה ל־.env והזן את המפתח למטה.
# אחרי כל שינוי: עצור והפעל מחדש את npm run dev (או בנה מחדש לפרודקשן).
# ללא מפתח: נעשה שימוש בסינון מקומי (mock) בלבד.
# שימו לב: משתני VITE_* נכללים ב-build של האפליקציה בדפדפן — אל תפרסמו מפתח רגיש לציבור;
# לפרודקשן מומלץ בעתיד Proxy בשרת / Edge Function.
# -----------------------------------------------------------------------------
VITE_OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Community Automation — UI mode label only. Webhook URLs MUST be set as Supabase
# Edge secrets (not VITE_): AUTOMATION_WEBHOOK_TEST_URL, AUTOMATION_WEBHOOK_PRODUCTION_URL, AUTOMATION_WEBHOOK_MODE
# Local Edge: copy supabase/edge-secrets.example → supabase/.env (gitignored).
# Hosted: Dashboard → Edge Functions → Secrets, or: supabase secrets set ...
# -----------------------------------------------------------------------------
VITE_AUTOMATION_WEBHOOK_MODE=test
# VITE_AUTOMATION_WEBHOOK_TEST_URL=        # optional mirror for local docs only — dispatch uses Edge secrets
# VITE_AUTOMATION_WEBHOOK_PRODUCTION_URL=

# Optional Edge secrets (documentation only — set in Dashboard / CLI, not in VITE):
# AUTOMATION_ALLOW_REAL_AUDIENCE_IN_TEST=true   # allow bulk segment campaigns when AUTOMATION_WEBHOOK_MODE=test (staging only)

# Email branding (Edge — used by automation-dispatch when wrapping HTML):
# EMAIL_LOGO_URL=https://...           # public HTTPS image URL for header logo
# EMAIL_BRAND_COLOR=#7c3aed            # optional accent bar color
# EMAIL_FOOTER_LINE=צוות Clicks        # optional footer line

# Client-only preview in Admin → Templates (optional; same logo URL as EMAIL_LOGO_URL):
# VITE_EMAIL_LOGO_URL=https://...

# Template variables (optional — used by {{community_name}}, {{community_url}}, {{support_email}}):
# VITE_COMMUNITY_NAME=Clicks
# VITE_COMMUNITY_URL=https://app.example.com
# VITE_SUPPORT_EMAIL=support@example.com

# Automation UI: emails (lowercase, comma-separated) that always see technical / developer automation tabs
# VITE_AUTOMATION_DEVELOPER_EMAILS=dev1@example.com,dev2@example.com
