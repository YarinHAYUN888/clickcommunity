# Client (safe to expose in built SPA — protected by RLS). Never put service_role here.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_or_publishable_key
# Optional alias for the same anon/public key:
# VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Optional — documentation only for tooling / Dashboard links
# VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_REF

# -----------------------------------------------------------------------------
# OpenAI — סינון התאמת משתמש בהרשמה (src/lib/ai/analyzeUser.ts → runUserAnalysis).
# העתק את הקובץ הזה ל־.env והזן את המפתח למטה.
# אחרי כל שינוי: עצור והפעל מחדש את npm run dev (או בנה מחדש לפרודקשן).
# ללא מפתח: נעשה שימוש בסינון מקומי (mock) בלבד.
# שימו לב: משתני VITE_* נכללים ב-build של האפליקציה בדפדפן — אל תפרסמו מפתח רגיש לציבור;
# לפרודקשן מומלץ בעתיד Proxy בשרת / Edge Function.
# -----------------------------------------------------------------------------
VITE_OPENAI_API_KEY=
