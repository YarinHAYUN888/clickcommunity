# Copy to supabase/.env for local `supabase functions serve` (see root .env.example).
# Hosted: Project Settings → Edge Functions → Secrets (same variable names).

# Onboarding email OTP → n8n production webhook
OTP_EMAIL_WEBHOOK_URL=https://redagentai.app.n8n.cloud/webhook/send-otp

# Subscription payment request → Make webhook (server-only; never expose in frontend)
MAKE_SUBSCRIPTION_WEBHOOK_URL=

AUTOMATION_WEBHOOK_TEST_URL=
AUTOMATION_WEBHOOK_PRODUCTION_URL=
AUTOMATION_WEBHOOK_MODE=test

# Email branding
EMAIL_LOGO_URL=
EMAIL_BRAND_COLOR=#7c3aed
EMAIL_FOOTER_LINE=צוות Clicks
EMAIL_SUPPORT_EMAIL=
